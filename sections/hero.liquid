<div class="hero">
  <div class="hero__media">
    {%- if section.settings.image != blank -%}
      <img
        src="{{ section.settings.image | image_url: width: 2000 }}"
        alt="{{ section.settings.heading }}"
        loading="eager"
        fetchpriority="high"
      >
    {%- else -%}
      <img src="https://images.unsplash.com/photo-1591946614720-90a587da4a36?w=2000&q=80" alt="Âme Pet" loading="eager">
    {%- endif -%}
  </div>
  <div class="hero__overlay"></div>
  <div class="hero__content">
    <p class="hero__eyebrow">{{ section.settings.eyebrow | default: 'Couro legítimo · Feito à mão' }}</p>
    <h1 class="hero__title">{{ section.settings.heading | default: 'Para quem ama de verdade' }}</h1>
    <p class="hero__subtitle">{{ section.settings.subheading | default: 'Coleiras, pingentes e bolsas artesanais que contam a história do seu pet.' }}</p>
    {%- if section.settings.button_label != blank -%}
      <a href="{{ section.settings.button_link | default: '/collections/all' }}" class="btn btn--primary">
        {{ section.settings.button_label }}
      </a>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "image_picker", "id": "image",         "label": "Imagem de fundo" },
    { "type": "text",         "id": "eyebrow",       "label": "Texto acima do título",  "default": "Couro legítimo · Feito à mão" },
    { "type": "text",         "id": "heading",       "label": "Título",                 "default": "Para quem ama de verdade" },
    { "type": "textarea",     "id": "subheading",    "label": "Subtítulo",              "default": "Coleiras, pingentes e bolsas artesanais que contam a história do seu pet." },
    { "type": "text",         "id": "button_label",  "label": "Texto do botão",         "default": "Explorar coleção" },
    { "type": "url",          "id": "button_link",   "label": "Link do botão" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}