{%- comment -%}
  Snippet: pendant-shapes
  Usage: {%- render 'pendant-shapes' -%}
  Renders the 4 pendant shape options.
{%- endcomment -%}

<div class="pendant-shapes-grid">
  <button type="button" class="pendant-shape-btn" data-shape="osso" data-emoji="🦴">
    <span class="pendant-shape-btn__emoji">🦴</span>
    <span class="pendant-shape-btn__label">Ossinho</span>
  </button>
  <button type="button" class="pendant-shape-btn" data-shape="coracao" data-emoji="❤️">
    <span class="pendant-shape-btn__emoji">❤️</span>
    <span class="pendant-shape-btn__label">Coração</span>
  </button>
  <button type="button" class="pendant-shape-btn" data-shape="flor" data-emoji="🌸">
    <span class="pendant-shape-btn__emoji">🌸</span>
    <span class="pendant-shape-btn__label">Flor</span>
  </button>
  <button type="button" class="pendant-shape-btn" data-shape="circulo" data-emoji="⭕">
    <span class="pendant-shape-btn__emoji">⭕</span>
    <span class="pendant-shape-btn__label">Redondo</span>
  </button>
</div>